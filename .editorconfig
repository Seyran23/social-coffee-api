root = true

# All files
[*]
indent_style = space
indent_size = 2
end_of_line = auto
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 80

# TypeScript/JavaScript files
[*.{ts,js}]
indent_style = space
indent_size = 2
max_line_length = 80

# JSON files
[*.json]
indent_style = space
indent_size = 2
max_line_length = 120

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Package.json files
[package.json]
indent_style = space
indent_size = 2
max_line_length = 120
