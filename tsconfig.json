{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    // DTOs use class-validator decorators without constructors; properties
    // are populated by plainToClass at runtime. Disabling avoids spurious
    // "no initializer" errors on every DTO class.
    "strictPropertyInitialization": false,
    // Many existing catch blocks rely on `error.message` directly.
    // Re-enable later in a focused refactor that adds proper narrowing.
    "useUnknownInCatchVariables": false,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "test/**/*", "prisma/**/*", "vitest.config.ts"],
  "exclude": ["node_modules", "dist"]
}
