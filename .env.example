# ─── Application ──────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development
LOG_LEVEL=debug

# Comma-separated list of allowed CORS origins for HTTP and WebSocket.
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173

# Set to "true" ONLY on local dev to send the refresh-token cookie over plain HTTP.
# Never set this in staging or production.
INSECURE_COOKIES_DEV_ONLY=true

# ─── Database ─────────────────────────────────────────────────────────────
# postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_coffee?schema=public

# ─── Initial admin (used by the seed script) ──────────────────────────────
# Change these immediately after first deploy.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# ─── JWT ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string
JWT_RESET_PASSWORD_SECRET=replace-me-with-a-third-long-random-string

# ms / s / m / h / d notation (zeit/ms format)
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=30d
JWT_RESET_PASSWORD_EXPIRATION=15m

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Cloudinary (image hosting) ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
